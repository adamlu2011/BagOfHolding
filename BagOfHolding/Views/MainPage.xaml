<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BagOfHolding.Views.MainPage"
             Title="Bag of Holding">

    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">

        <Label Text="Welcome to the Table" 
               FontSize="28" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" 
               Margin="0,0,0,30"/>

        <Button x:Name="HostGameBtn" 
                Text="Host Game (DM)" 
                HeightRequest="60"
                FontSize="18"/>

        <Label Text="Start a new session or load an existing campaign database." 
               FontSize="12" 
               TextColor="Gray" 
               HorizontalOptions="Center" />

        <BoxView HeightRequest="1" Color="DimGray" Margin="0,20" />

        <Button x:Name="JoinGameBtn" 
                Text="Join Game (Player)" 
                HeightRequest="60"
                FontSize="18"
                BackgroundColor="DarkSlateBlue"/>

        <Label Text="Connect to an active DM on your local network." 
               FontSize="12" 
               TextColor="Gray" 
               HorizontalOptions="Center" />

    </VerticalStackLayout>
</ContentPage>
